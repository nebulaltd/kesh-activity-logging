{
  "name": "kesh-activity-logging",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/db/migrate.ts && bun run src/index.ts",
    "build": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "zod": "^3.23.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/bun": "^1.1.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0"
  }
}
